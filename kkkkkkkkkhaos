-- ================================================================
--  VELOCITY SMOOTHING
-- ================================================================
local velocityHistory={}; local accelerationHistory={}
local W_TOTALS={[2]=3,[4]=10,[6]=21}
local DIR_THRESH=math.cos(math.rad(55))
local function getBufSize(sp) return sp>35 and 2 or sp>22 and 4 or 6 end
local function getSmoothedVelocity(hrp)
    local cur=hrp.Velocity; local now=tick(); local sp=Vector2.new(cur.X,cur.Z).Magnitude; local bs=getBufSize(sp)
    if not velocityHistory[hrp] then
        velocityHistory[hrp]={}
        for i=1,bs do velocityHistory[hrp][i]={vel=cur,t=now-(bs-i)*0.016} end
        accelerationHistory[hrp]=Vector3.new(0,0,0); return cur,false
    end
    local h=velocityHistory[hrp]; local ps=#h
    if bs<ps then local t={}; for i=ps-bs+1,ps do t[#t+1]=h[i] end; velocityHistory[hrp]=t; h=t
    elseif bs>ps then local e={}; local o=h[1]
        for i=1,bs-ps do e[i]={vel=o.vel,t=o.t-(bs-ps-i+1)*0.016} end
        for i=1,ps do e[bs-ps+i]=h[i] end; velocityHistory[hrp]=e; h=e end
    local lv=h[bs].vel; local cXZ=Vector2.new(cur.X,cur.Z); local lXZ=Vector2.new(lv.X,lv.Z)
    local cM=cXZ.Magnitude; local lM=lXZ.Magnitude
    if cM>2 and lM>2 and (cXZ/cM):Dot(lXZ/lM)<DIR_THRESH then
        for i=1,bs do h[i]={vel=cur,t=now-(bs-i)*0.016} end
        accelerationHistory[hrp]=Vector3.new(0,0,0); return cur,true
    end
    for i=1,bs-1 do h[i]=h[i+1] end; h[bs]={vel=cur,t=now}
    local sT,sVx,sVz,sT2,sTVx,sTVz=0,0,0,0,0,0; local t0=h[1].t
    for i=1,bs do local dt=h[i].t-t0; local vx=h[i].vel.X; local vz=h[i].vel.Z
        sT=sT+dt;sVx=sVx+vx;sVz=sVz+vz;sT2=sT2+dt*dt;sTVx=sTVx+dt*vx;sTVz=sTVz+dt*vz end
    local dn=bs*sT2-sT*sT; local aX,aZ=0,0
    if math.abs(dn)>1e-6 then aX=(bs*sTVx-sT*sVx)/dn; aZ=(bs*sTVz-sT*sVz)/dn end
    accelerationHistory[hrp]=Vector3.new(aX,0,aZ)
    local wT=W_TOTALS[bs] or bs*(bs+1)/2; local sv=Vector3.new(0,0,0)
    for i=1,bs do sv=sv+h[i].vel*i end; return sv/wT,false
end
local function getAccel(hrp) return accelerationHistory[hrp] or Vector3.new(0,0,0) end
local function getRepTime(hrp) local h=velocityHistory[hrp]; return (h and #h>0) and h[#h].t or tick() end

-- ================================================================
--  PREDIÇÃO
-- ================================================================
local function CalcularPredicao(alvoHRP,alvoAim,minhaPos)
    if not alvoHRP or not alvoHRP.Parent then return nil end
    if not alvoAim or not alvoAim.Parent then return nil end
    local raw=alvoHRP.Velocity; local sm,dc=getSmoothedVelocity(alvoHRP); local ac=getAccel(alvoHRP)
    local rLag=math.min(tick()-getRepTime(alvoHRP),0.05)
    local vel=dc and Vector3.new(raw.X+ac.X*rLag,raw.Y,raw.Z+ac.Z*rLag) or Vector3.new(sm.X+ac.X*rLag,sm.Y,sm.Z+ac.Z*rLag)
    local hrpEx=alvoHRP.Position+vel*rLag; local hOff=alvoAim.Position-alvoHRP.Position; local aPos=hrpEx+hOff
    local pt=0
    if sheriffConfig.PingPrediction then local p=pingCache; pt=p*0.001*sheriffConfig.PingSensitivity
        if p>150 then pt=pt*1.35 elseif p>100 then pt=pt*1.20 end end
    local eT=pt+sheriffConfig.LeadTime
    local hD=Vector2.new(aPos.X-minhaPos.X,aPos.Z-minhaPos.Z).Magnitude
    local tT=hD/BULLET_SPEED+eT; local wC=0.50
    for i=0,7 do local w=math.max(0.40,0.50-i*0.02); local tv=math.max(0,tT-eT)
        local fX=aPos.X+vel.X*tT+w*ac.X*tv*tv; local fZ=aPos.Z+vel.Z*tT+w*ac.Z*tv*tv
        local nD=Vector2.new(fX-minhaPos.X,fZ-minhaPos.Z).Magnitude; local tN=nD/BULLET_SPEED+eT
        if math.abs(tN-tT)*BULLET_SPEED<0.08 then wC=w; tT=tN; break end; wC=w; tT=tN end
    local tvF=math.max(0,tT-eT)
    local fX=aPos.X+vel.X*tT+wC*ac.X*tvF*tvF; local fZ=aPos.Z+vel.Z*tT+wC*ac.Z*tvF*tvF
    if Vector2.new(raw.X,raw.Z).Magnitude<3 and Vector2.new(ac.X,ac.Z).Magnitude>2 then
        fX=aPos.X+vel.X*tT*0.4; fZ=aPos.Z+vel.Z*tT*0.4 end
    local dX=(fX-aPos.X)*sheriffConfig.HorizontalMultiplier+sheriffConfig.XMultiplier*10
    local dZ=(fZ-aPos.Z)*sheriffConfig.HorizontalMultiplier+sheriffConfig.ZMultiplier*10
    local dY=0; local vY=raw.Y; local g=196.2
    if sheriffConfig.JumpPrediction then
        local hum=alvoHRP.Parent and alvoHRP.Parent:FindFirstChild("Humanoid")
        local st=hum and hum:GetState()
        if st==Enum.HumanoidStateType.Freefall or st==Enum.HumanoidStateType.Jumping then
            local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Blacklist
            rp.FilterDescendantsInstances={alvoHRP.Parent}
            local rr=workspace:Raycast(alvoHRP.Position,Vector3.new(0,-60,0),rp)
            local gd=rr and (alvoHRP.Position.Y-rr.Position.Y) or 999
            local hAG=hOff.Y+3; local gC=0.5*g*rLag*rLag; local tP=999
            if vY<0 then local ae=0.5*g;local be=-vY;local ce=-gd;local di=be*be-4*ae*ce
                if di>=0 then local sq=math.sqrt(di); local r1=(-be+sq)/(2*ae); local r2=(-be-sq)/(2*ae)
                    if r1>0 and r2>0 then tP=math.min(r1,r2) elseif r1>0 then tP=r1 elseif r2>0 then tP=r2 end end end
            if vY>5 then dY=(vY*tT)-(0.5*g*tT*tT)-gC
            elseif math.abs(vY)<=5 then dY=-(0.5*g*tT*tT)-gC
            else if tP<tT then dY=rr and (rr.Position.Y+hAG)-aPos.Y or (vY*tT)-(0.5*g*tT*tT)-gC
                else dY=(vY*tT)-(0.5*g*tT*tT)-gC end end
            dY=dY*sheriffConfig.VerticalMultiplier
            local hDF=Vector2.new(aPos.X-minhaPos.X,aPos.Z-minhaPos.Z).Magnitude
            if hDF>80 then dY=dY-(hDF-80)*0.008*sheriffConfig.VerticalDistanceScale end
        end
    end
    local vMag=Vector2.new(raw.X,raw.Z).Magnitude
    local hDF2=Vector2.new(aPos.X-minhaPos.X,aPos.Z-minhaPos.Z).Magnitude
    local sL=math.max(40,vMag*(hDF2/BULLET_SPEED)*1.0); local pDM=Vector2.new(dX,dZ).Magnitude
    if pDM>sL then local sc=sL/pDM; dX=dX*sc; dZ=dZ*sc end
    return Vector3.new(aPos.X+dX,aPos.Y+dY,aPos.Z+dZ)
end

