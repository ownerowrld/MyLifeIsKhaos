-- ==================== HITBOX ====================

local hitboxParts       = {}
local hitboxConnections = {}
local originalSizes     = {}

local function createHitboxForPlayer(player)
    if player == LP then return end
    if not player.Character then return end
    local char  = player.Character
    local hrp   = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local pName = player.Name

    -- Salva o tamanho original APENAS se ainda não foi expandido
    -- evita salvar um tamanho já modificado pelo hitbox em caso de re-aplicação
    if not originalSizes[pName] then
        local sz = hrp.Size
        -- tamanho padrão do HRP no MM2 é ~2,2,1 — se já estiver expandido, usa o padrão
        if sz.X <= 3 and sz.Y <= 5 and sz.Z <= 3 then
            originalSizes[pName] = sz
        else
            originalSizes[pName] = Vector3.new(2, 2, 1)
        end
    end

    hrp.Size = Vector3.new(hitboxConfig.size, hitboxConfig.size, hitboxConfig.size)
    hrp.Transparency = 1  -- totalmente invisível: não entra no bounding box do ESP Highlight
    hrp.Material = Enum.Material.ForceField
    hrp.CanCollide = false
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = false end
    end
    local old = hrp:FindFirstChild("HitboxVisual")
    if old then old:Destroy() end
    if hitboxConfig.visible then
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "HitboxVisual"
        box.Adornee = hrp
        box.Size = hrp.Size
        box.Color3 = hitboxConfig.color
        box.Transparency = hitboxConfig.transparency
        box.AlwaysOnTop = true
        box.ZIndex = 1
        box.Parent = hrp
    end
    hitboxParts[pName] = hrp
end

local function updateAllHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LP and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local newSize = Vector3.new(hitboxConfig.size, hitboxConfig.size, hitboxConfig.size)
                if hrp.Size ~= newSize then
                    hrp.Size = newSize
                    hrp.Transparency = 1  -- totalmente invisível: não entra no bounding box do ESP Highlight
                    hrp.Material = Enum.Material.ForceField
                    hrp.CanCollide = false
                    for _, part in pairs(player.Character:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end
                local visual = hrp:FindFirstChild("HitboxVisual")
                if hitboxConfig.visible then
                    if not visual then
                        visual = Instance.new("BoxHandleAdornment")
                        visual.Name = "HitboxVisual"
                        visual.Adornee = hrp
                        visual.AlwaysOnTop = true
                        visual.ZIndex = 1
                        visual.Parent = hrp
                    end
                    visual.Size        = hrp.Size
                    visual.Color3      = hitboxConfig.color
                    visual.Transparency = hitboxConfig.transparency
                else
                    if visual then visual:Destroy() end
                end
            else
                createHitboxForPlayer(player)
            end
        end
    end
end

local function startHitbox()
    for _, player in ipairs(Players:GetPlayers()) do createHitboxForPlayer(player) end
    hitboxConnections.playerAdded = Players.PlayerAdded:Connect(function(player)
        hitboxConnections[player.Name] = player.CharacterAdded:Connect(function()
            task.wait(0.5)
            if hitboxConfig.enabled then createHitboxForPlayer(player) end
        end)
    end)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LP then
            hitboxConnections[player.Name] = player.CharacterAdded:Connect(function()
                task.wait(0.5)
                if hitboxConfig.enabled then createHitboxForPlayer(player) end
            end)
        end
    end
    local lastHitUpdate = 0
    hitboxConnections.heartbeat = RunService.Heartbeat:Connect(function()
        if not hitboxConfig.enabled then return end
        local now = tick()
        if now - lastHitUpdate < 0.1 then return end
        lastHitUpdate = now
        updateAllHitboxes()
    end)
    hitboxConnections.playerRemoving = Players.PlayerRemoving:Connect(function(player)
        local pName = player.Name
        if hitboxParts[pName] and hitboxParts[pName].Parent then
            pcall(function()
                local hrp = hitboxParts[pName]
                local v   = hrp:FindFirstChild("HitboxVisual")
                if v then v:Destroy() end
                hrp.Size = originalSizes[pName] or Vector3.new(2, 2, 1)
                hrp.Transparency = 1
            end)
        end
        originalSizes[pName] = nil
        hitboxParts[pName]   = nil
        if hitboxConnections[pName] then
            hitboxConnections[pName]:Disconnect()
            hitboxConnections[pName] = nil
        end
    end)
end

local function stopHitbox()
    for _, conn in pairs(hitboxConnections) do
        if conn then
            pcall(function()
                if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
            end)
        end
    end
    hitboxConnections = {}

    -- Restaura hitboxParts conhecidos
    for pName, hrp in pairs(hitboxParts) do
        if hrp and hrp.Parent then
            pcall(function()
                local v = hrp:FindFirstChild("HitboxVisual")
                if v then v:Destroy() end
                hrp.Size         = originalSizes[pName] or Vector3.new(2, 2, 1)
                hrp.Transparency = 1  -- mantém invisível (padrão do MM2)
                hrp.Material     = Enum.Material.SmoothPlastic
                hrp.CanCollide   = true
                local char = hrp.Parent
                if char then
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = true end
                    end
                end
            end)
        end
    end

    -- Varredura completa: garante que NENHUM player fique com hitbox expandido
    -- cobre casos de players que não estavam em hitboxParts (entraram depois, respawnaram, etc.)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LP and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                pcall(function()
                    local visual = hrp:FindFirstChild("HitboxVisual")
                    if visual then visual:Destroy() end
                    -- só restaura se o tamanho estiver claramente expandido
                    local stored = originalSizes[player.Name]
                    if stored then
                        hrp.Size = stored
                    elseif hrp.Size.X > 3 or hrp.Size.Y > 5 or hrp.Size.Z > 3 then
                        -- fallback seguro: tamanho padrão do HRP no MM2
                        hrp.Size = Vector3.new(2, 2, 1)
                    end
                    hrp.Transparency = 1
                    hrp.Material     = Enum.Material.SmoothPlastic
                    hrp.CanCollide   = true
                    for _, part in pairs(player.Character:GetDescendants()) do
                        if part:IsA("BasePart") and part ~= hrp then
                            part.CanCollide = true
                        end
                    end
                end)
            end
        end
    end

    hitboxParts   = {}
    originalSizes = {}
end

-- ==================== ESP ====================

local espConnections = {}
local activeESP      = {}
local espRunning     = false
local roleCache      = {}  -- [playerName] = "Murderer" | "Sheriff" | "Innocent" | "Lobby"

-- RemoteFunction do MM2 (mesmo que o Nexus usa)
local playerDataRemote = nil
local function getPlayerDataRemote()
    if playerDataRemote then return playerDataRemote end
    local ok, r = pcall(function()
        return game:GetService("ReplicatedStorage"):FindFirstChild("GetPlayerData", true)
    end)
    if ok and r then playerDataRemote = r end
    return playerDataRemote
end

-- Atualiza roleCache via InvokeServer a cada 0.25s (igual ao Nexus)
-- Usa plrData.Dead para detectar morte com precisão do servidor
local rolePollThread = nil

local function startRolePoll()
    if rolePollThread then return end
    rolePollThread = task.spawn(function()
        while espRunning do
            local remote = getPlayerDataRemote()
            if remote then
                local ok, data = pcall(function() return remote:InvokeServer() end)
                if ok and type(data) == "table" then
                    local newCache = {}
                    for plrName, plrData in pairs(data) do
                        if type(plrData) == "table" then
                            -- morto, sem papel ou papel vazio = Lobby (inocente)
                            if plrData.Dead or not plrData.Role or plrData.Role == "" then
                                newCache[plrName] = "Lobby"
                            else
                                newCache[plrName] = plrData.Role
                            end
                        end
                    end
                    roleCache = newCache
                end
            end
            task.wait(0.25)
        end
    end)
end

local function stopRolePoll()
    if rolePollThread then
        task.cancel(rolePollThread)
        rolePollThread = nil
    end
    roleCache = {}
end

-- Retorna a cor correta para o player
-- Prioridade:
-- 1. Checagem ao vivo de Backpack/Character (detecta quem pegou a arma caída)
-- 2. roleCache do servidor (para murderer e mortos)
local function getRoleColor(playerName)
    local plr = Players:FindFirstChild(playerName)
    if plr then
        local char = plr.Character
        local bp   = plr:FindFirstChild("Backpack")
        -- checa ao vivo: faca = murderer, arma = sheriff
        local hasKnife = (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife"))
        local hasGun   = (char and char:FindFirstChild("Gun"))   or (bp and bp:FindFirstChild("Gun"))
        if hasKnife then return espConfig.murdererColor end
        if hasGun   then return espConfig.sheriffColor  end
    end
    -- fallback: roleCache do servidor (cobre murderer sem faca visível e mortos)
    local role = roleCache[playerName]
    if role == "Murderer" then return espConfig.murdererColor end
    if role == "Sheriff"  then return espConfig.sheriffColor  end
    return espConfig.innocentColor
end

-- Loop global de atualização visual do ESP a cada 0.2s
local espElapsed = 0
RunService.Heartbeat:Connect(function(dt)
    espElapsed = espElapsed + dt
    if espElapsed < 0.2 then return end
    espElapsed = 0
    if not espConfig.enabled then return end

    for i = #activeESP, 1, -1 do
        local e = activeESP[i]
        -- remove entrada se o character saiu do jogo
        if not e.character or not e.character.Parent then
            if e.highlight and e.highlight.Parent then e.highlight:Destroy() end
            if e.tag       and e.tag.Parent       then e.tag:Destroy()       end
            table.remove(activeESP, i)
        else
            local color = getRoleColor(e.player.Name)
            e.highlight.OutlineColor = color
            e.label.TextColor3       = color
            e.label.Text             = e.player.Name
            e.label.TextSize         = espConfig.nameSize
            e.tag.Enabled            = espConfig.nameEnabled
        end
    end
end)

-- Limpa instâncias de ESP de um player
local function CleanupPlayer(plr)
    if not plr then return end
    local char = plr.Character
    if not char then return end
    local holder = char:FindFirstChild("ESPHolder")
    if holder then holder:Destroy() end
    local head = char:FindFirstChild("Head")
    if head then
        local tag = head:FindFirstChild("MoonTag")
        if tag then tag:Destroy() end
    end
end

local function ApplyESP(targetPlayer, character)
    if not character then return end

    local head = character:WaitForChild("Head", 5)
    if not head then return end

    -- Pasta isolada para todos os objetos do ESP deste player
    local oldHolder = character:FindFirstChild("ESPHolder")
    if oldHolder then oldHolder:Destroy() end

    local holder = Instance.new("Folder")
    holder.Name   = "ESPHolder"
    holder.Parent = character

    -- Highlight no character inteiro (corpo completo)
    -- O HRP expandido pelo hitbox não interfere porque setamos
    -- Transparency = 1 nele, tornando-o invisível para o bounding box do Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name              = "ESPHighlight"
    highlight.Adornee           = character
    highlight.FillTransparency  = 1
    highlight.OutlineTransparency = 0
    highlight.DepthMode         = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.OutlineColor      = getRoleColor(targetPlayer.Name)
    highlight.Parent            = holder

    -- BillboardGui no Head — posição estável
    local oldTag = head:FindFirstChild("MoonTag")
    if oldTag then oldTag:Destroy() end

    local tag = Instance.new("BillboardGui")
    tag.Name        = "MoonTag"
    tag.Size        = UDim2.new(0, 200, 0, 40)
    tag.AlwaysOnTop = true
    tag.StudsOffset = Vector3.new(0, 1.5, 0)
    tag.Parent      = head

    local label = Instance.new("TextLabel")
    label.Name                   = "Label"
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = targetPlayer.Name
    label.Font                   = Enum.Font.GothamBold
    label.TextSize               = espConfig.nameSize
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextColor3             = getRoleColor(targetPlayer.Name)
    label.Parent                 = tag

    table.insert(activeESP, {
        player    = targetPlayer,
        character = character,
        highlight = highlight,
        tag       = tag,
        label     = label,
    })
end

local function CreateESP(targetPlayer)
    if targetPlayer == LP then return end
    if targetPlayer.Character then
        task.spawn(ApplyESP, targetPlayer, targetPlayer.Character)
    end
    local ref = { player = targetPlayer }
    ref.conn  = targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.15)  -- aguarda partes do character carregarem
        task.spawn(ApplyESP, targetPlayer, char)
    end)
    table.insert(espConnections, ref)
end

local function enablePlayerESP()
    -- reset completo se já estava ligado
    if espRunning then
        espRunning        = false
        espConfig.enabled = false
        stopRolePoll()
    end
    espRunning        = true
    espConfig.enabled = true

    -- limpa conexões e instâncias anteriores
    for _, conn in pairs(espConnections) do
        if conn.conn and conn.conn.Connected then conn.conn:Disconnect() end
    end
    for _, e in pairs(activeESP) do
        if e.highlight and e.highlight.Parent then e.highlight:Destroy() end
        if e.tag       and e.tag.Parent       then e.tag:Destroy()       end
    end
    espConnections = {}
    activeESP      = {}

    startRolePoll()

    for _, plr in pairs(Players:GetPlayers()) do CreateESP(plr) end

    local addedRef = {}
    addedRef.conn  = Players.PlayerAdded:Connect(CreateESP)
    table.insert(espConnections, addedRef)

    local removingRef = {}
    removingRef.conn  = Players.PlayerRemoving:Connect(function(plr)
        for i = #activeESP, 1, -1 do
            if activeESP[i].player == plr then
                if activeESP[i].highlight and activeESP[i].highlight.Parent then
                    activeESP[i].highlight:Destroy()
                end
                if activeESP[i].tag and activeESP[i].tag.Parent then
                    activeESP[i].tag:Destroy()
                end
                table.remove(activeESP, i)
            end
        end
        for i = #espConnections, 1, -1 do
            local c = espConnections[i]
            if c.player == plr then
                if c.conn and c.conn.Connected then c.conn:Disconnect() end
                table.remove(espConnections, i)
            end
        end
        CleanupPlayer(plr)
    end)
    table.insert(espConnections, removingRef)
end

local function disablePlayerESP()
    espRunning        = false
    espConfig.enabled = false
    stopRolePoll()

    for _, conn in pairs(espConnections) do
        if conn.conn and conn.conn.Connected then conn.conn:Disconnect() end
    end
    for _, e in pairs(activeESP) do
        if e.highlight and e.highlight.Parent then e.highlight:Destroy() end
        if e.tag       and e.tag.Parent       then e.tag:Destroy()       end
    end
    espConnections = {}
    activeESP      = {}

    for _, plr in pairs(Players:GetPlayers()) do CleanupPlayer(plr) end
end

