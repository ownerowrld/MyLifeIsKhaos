            else local wa=v.Anchored; v.Anchored=false; v.CFrame=root.CFrame
                task.wait(0.05); if v and v.Parent then v.Anchored=wa end end; return
        end
    end
end
local function startGetGunAuto()
    if getGunConn then return end
