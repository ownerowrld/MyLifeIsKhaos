-- ================================================================
--  SISTEMA DE CONFIG (writefile/readfile do executor)
-- ================================================================
local CONFIG_DIR  = "KhaosHub/"
local CONFIG_EXT  = ".json"
local MAX_SLOTS   = 8
pcall(function() if not isfolder(CONFIG_DIR) then makefolder(CONFIG_DIR) end end)

local function serializeConfig()
    return game:GetService("HttpService"):JSONEncode({
        PingPrediction       = sheriffConfig.PingPrediction,
        PingSensitivity      = sheriffConfig.PingSensitivity,
        JumpPrediction       = sheriffConfig.JumpPrediction,
        HorizontalMultiplier = sheriffConfig.HorizontalMultiplier,
        VerticalMultiplier   = sheriffConfig.VerticalMultiplier,
        MaxPredictionDistance= sheriffConfig.MaxPredictionDistance,
        VerticalDistanceScale= sheriffConfig.VerticalDistanceScale,
        LeadTime             = sheriffConfig.LeadTime,
        XMultiplier          = sheriffConfig.XMultiplier,
        ZMultiplier          = sheriffConfig.ZMultiplier,
        UnequipAfterShot     = sheriffConfig.UnequipAfterShot,
        wallCheck            = autoShotConfig.wallCheck,
        delayTiro            = delayTiro,
        delayHolster         = delayHolster,
        BULLET_SPEED         = BULLET_SPEED,
        autoShotKeyName      = autoShotKey.Name,
        getGunKeyName        = getGunKey.Name,
        autoShotKeyEnabled   = autoShotKeyEnabled,
        getGunKeyEnabled     = getGunKeyEnabled,
    })
end

local function applyConfig(t)
    if not t then return end
    if t.PingPrediction~=nil        then sheriffConfig.PingPrediction=t.PingPrediction end
    if t.PingSensitivity            then sheriffConfig.PingSensitivity=t.PingSensitivity end
    if t.JumpPrediction~=nil        then sheriffConfig.JumpPrediction=t.JumpPrediction end
    if t.HorizontalMultiplier       then sheriffConfig.HorizontalMultiplier=t.HorizontalMultiplier end
    if t.VerticalMultiplier         then sheriffConfig.VerticalMultiplier=t.VerticalMultiplier end
    if t.MaxPredictionDistance      then sheriffConfig.MaxPredictionDistance=t.MaxPredictionDistance end
    if t.VerticalDistanceScale      then sheriffConfig.VerticalDistanceScale=t.VerticalDistanceScale end
    if t.LeadTime                   then sheriffConfig.LeadTime=t.LeadTime end
    if t.XMultiplier                then sheriffConfig.XMultiplier=t.XMultiplier end
    if t.ZMultiplier                then sheriffConfig.ZMultiplier=t.ZMultiplier end
    if t.UnequipAfterShot~=nil      then sheriffConfig.UnequipAfterShot=t.UnequipAfterShot end
    if t.wallCheck~=nil             then autoShotConfig.wallCheck=t.wallCheck end
    if t.delayTiro                  then delayTiro=t.delayTiro end
    if t.delayHolster               then delayHolster=t.delayHolster end
    if t.BULLET_SPEED               then BULLET_SPEED=t.BULLET_SPEED end
    if t.autoShotKeyEnabled~=nil    then autoShotKeyEnabled=t.autoShotKeyEnabled end
    if t.getGunKeyEnabled~=nil      then getGunKeyEnabled=t.getGunKeyEnabled end
    if t.autoShotKeyName then pcall(function() autoShotKey=Enum.KeyCode[t.autoShotKeyName] end) end
    if t.getGunKeyName   then pcall(function() getGunKey  =Enum.KeyCode[t.getGunKeyName]   end) end
end

local function saveConfig(slotName)
    local ok,err=pcall(function() writefile(CONFIG_DIR..slotName..CONFIG_EXT, serializeConfig()) end)
    return ok
end

local function loadConfig(slotName)
    local ok,data=pcall(function() return readfile(CONFIG_DIR..slotName..CONFIG_EXT) end)
    if not ok or not data then return false end
    local ok2,t=pcall(function() return game:GetService("HttpService"):JSONDecode(data) end)
    if not ok2 or not t then return false end
    applyConfig(t); return true
end

local function deleteConfig(slotName)
    pcall(function() delfile(CONFIG_DIR..slotName..CONFIG_EXT) end)
end

local function listConfigs()
    local list={}
    local ok,files=pcall(function() return listfiles(CONFIG_DIR) end)
    if ok and files then
        for _,f in ipairs(files) do
            local name=f:match("([^/\\]+)%.json$")
            if name then list[#list+1]=name end
        end
    end
    return list
end

