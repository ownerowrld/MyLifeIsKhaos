-- ==================== ANTI FLING ====================

local antiFlingConnections = {}
local antiFlingHeartbeat   = nil

local function startAntiFling()
    local function applyToPlayer(player)
        if player == LP then return end
        local char = player.Character
        if not char then return end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    local function hookPlayer(player)
        if player == LP then return end
        applyToPlayer(player)
        antiFlingConnections[player.Name] = player.CharacterAdded:Connect(function()
            task.wait()
            applyToPlayer(player)
        end)
    end
    for _, player in pairs(Players:GetPlayers()) do hookPlayer(player) end
    antiFlingConnections["PlayerAdded"] = Players.PlayerAdded:Connect(hookPlayer)
    antiFlingHeartbeat = RunService.Heartbeat:Connect(function()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LP and player.Character then
                for _, part in pairs(player.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
                end
            end
        end
    end)
end

local function stopAntiFling()
    if antiFlingHeartbeat then antiFlingHeartbeat:Disconnect(); antiFlingHeartbeat = nil end
    for _, conn in pairs(antiFlingConnections) do conn:Disconnect() end
    antiFlingConnections = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP and player.Character then
            for _, part in pairs(player.Character:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
    end
end

-- ==================== KNIFE AURA ====================

local auraEnabled         = false
local auraDistance        = 7.1
local legitMode           = false
local guardarFaca         = false
local knifeEquippedByAura = false
local auraConnection      = nil
local lastFireTime        = 0
local FIRE_COOLDOWN       = 0.15
local lastAuraTarget      = nil
local lastAuraTargetAlive = true

local function getRole()
    local char = LP.Character
    local bp   = LP:FindFirstChild("Backpack")
    return (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife"))
end

local function knifeIsEquipped()
    local char = LP.Character
    if not char then return nil end
    return char:FindFirstChild("Knife")
end

local function equipKnifeAura()
    local char = LP.Character
    if not char then return false end
    local bp = LP:FindFirstChild("Backpack")
    if not bp then return false end
    local knife = bp:FindFirstChild("Knife")
    if knife then
        knife.Parent = char
        knifeEquippedByAura = true
        return true
    end
    return false
end

local function unequipKnifeAura()
    local char = LP.Character
    if not char then return end
    local knife = char:FindFirstChild("Knife")
    if not knife then knifeEquippedByAura = false; return end
    local bp = LP:FindFirstChild("Backpack")
    if not bp then return end
    knife.Parent = bp
    knifeEquippedByAura = false
end

local function isAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChild("Humanoid")
    return hum ~= nil and hum.Health > 0
end

local function getKnifeRemote(knife)
    if not knife then return nil end
    return knife:FindFirstChild("HandleTouched", true)
end

local function fireSlash(knife, targetHRP)
    local now = tick()
    if now - lastFireTime < FIRE_COOLDOWN then return end
    lastFireTime = now
    task.spawn(function()
        local originalCFrame = targetHRP and targetHRP.CFrame
        local handle = knife:FindFirstChild("Handle")
        if handle and targetHRP and targetHRP.Parent then
            pcall(function() targetHRP.CFrame = handle.CFrame end)
        end
        local handleTouched = getKnifeRemote(knife)
        if handleTouched then
            pcall(function() handleTouched:FireServer(targetHRP) end)
        end
        local events = knife:FindFirstChild("Events")
        if events then
            local ks = events:FindFirstChild("KnifeStabbed")
            if ks then pcall(function() ks:FireServer(targetHRP) end) end
        end
        RunService.RenderStepped:Wait()
        if targetHRP and targetHRP.Parent and originalCFrame then
            pcall(function() targetHRP.CFrame = originalCFrame end)
        end
    end)
end

local function findNearestAura()
    local char = LP.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil, nil end
    local closest, closestDist, closestHRP = nil, auraDistance, nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local otherHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = p.Character:FindFirstChild("Humanoid")
            local pBp = p:FindFirstChild("Backpack")
            local hasKnife = p.Character:FindFirstChild("Knife") or (pBp and pBp:FindFirstChild("Knife"))
            if otherHRP and humanoid and humanoid.Health > 0 and not hasKnife then
                local d = (myHRP.Position - otherHRP.Position).Magnitude
                if d < closestDist then
                    closest = p; closestDist = d; closestHRP = otherHRP
                end
            end
        end
    end
    return closest, closestHRP
end

local function onAuraHeartbeat()
    if not auraEnabled then return end
    local char = LP.Character
    if not char then return end
    local humLocal = char:FindFirstChild("Humanoid")
    if not humLocal or humLocal.Health <= 0 then return end
    if not getRole() then return end

    if lastAuraTarget then
        local aliveNow = isAlive(lastAuraTarget)
        if lastAuraTargetAlive and not aliveNow then
            -- alvo morreu
            if not guardarFaca then
                -- guardarFaca OFF: desequipa a faca
                unequipKnifeAura()
            end
            -- guardarFaca ON: não faz nada, faca fica no char
            lastAuraTarget      = nil
            lastAuraTargetAlive = true
        else
            lastAuraTargetAlive = aliveNow
        end
    end

    local target, targetHRP = findNearestAura()
    if target and targetHRP then
        if lastAuraTarget ~= target then
            lastAuraTarget      = target
            lastAuraTargetAlive = true
        end
        local knife = knifeIsEquipped()
        if not knife then
            if equipKnifeAura() then knife = knifeIsEquipped() end
        end
        if knife then
            fireSlash(knife, targetHRP)
            if legitMode then
                lastAuraTarget      = nil
                lastAuraTargetAlive = true
                return
            end
        end
    else
        -- sem alvo no range: desequipa só se guardarFaca estiver OFF
        if knifeEquippedByAura and not guardarFaca then
            unequipKnifeAura()
        end
    end
end

local function setAura(state)
    auraEnabled = state
    if state then
        if not auraConnection then
            auraConnection = RunService.Heartbeat:Connect(onAuraHeartbeat)
        end
    else
        if auraConnection then auraConnection:Disconnect(); auraConnection = nil end
        -- só desequipa ao desligar a aura se guardarFaca estiver OFF
        if not guardarFaca then
            unequipKnifeAura()
        else
            knifeEquippedByAura = false
        end
        lastAuraTarget      = nil
        lastAuraTargetAlive = true
    end
end

