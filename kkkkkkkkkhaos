local function makeKeybindRow(parent,order,label,defKey,defOn,onKey,onToggle)
    local row=makeRow(parent,order,44); makeLbl(row,label,11)
    local tf=makeToggle(row,UDim2.new(1,-54,0.5,-9),defOn)
    if onToggle then tf.AttributeChanged:Connect(function(a) if a=="IsOn" then onToggle(tf:GetAttribute("IsOn")) end end) end
    local kbBtn=Instance.new("TextButton",row); kbBtn.BorderSizePixel=0; kbBtn.TextSize=11
    kbBtn.TextColor3=Color3.fromRGB(154,69,222); kbBtn.BackgroundColor3=Color3.fromRGB(16,0,27)
    kbBtn.FontFace=Font.new("rbxasset://fonts/families/GothamSSm.json",Enum.FontWeight.Bold)
    kbBtn.Size=UDim2.new(0,38,0,22); kbBtn.Text=defKey or "E"
    kbBtn.Name="KeybindBtn"; kbBtn.Position=UDim2.new(1,-100,0.5,-11)
    corner(kbBtn,3); mkS(kbBtn,Color3.fromRGB(51,0,97))
    local listening=false
    local function startListen()
        if listening then return end; listening=true
        kbBtn.Text="..."; kbBtn.TextColor3=Color3.fromRGB(204,136,255)
        local con; con=UIS.InputBegan:Connect(function(i,gp)
            if gp then return end
            if i.UserInputType==Enum.UserInputType.Keyboard then
                local n=i.KeyCode.Name; kbBtn.Text=n:sub(1,6)
                kbBtn.TextColor3=Color3.fromRGB(153,68,221); listening=false; con:Disconnect()
                if onKey then onKey(i.KeyCode) end
            end
        end)
    end
    kbBtn.MouseButton1Click:Connect(startListen)
    kbBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then startListen() end end)
    local tiTF2=TweenInfo.new(0.12,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
    local function setToggleKB(v)
        tf:SetAttribute("IsOn",v)
        TS:Create(tf,tiTF2,{BackgroundColor3=v and Color3.fromRGB(61,0,107) or Color3.fromRGB(17,17,17)}):Play()
        local s=tf:FindFirstChildOfClass("UIStroke"); if s then s.Color=v and Color3.fromRGB(119,0,187) or Color3.fromRGB(34,0,56) end
        local knob=tf:FindFirstChild("Knob")
        if knob then TS:Create(knob,tiTF2,{Position=v and UDim2.fromOffset(19,3) or UDim2.fromOffset(3,3),BackgroundColor3=v and Color3.fromRGB(187,119,255) or Color3.fromRGB(85,85,85)}):Play() end
    end
    local function setKeyBtn(keyCode)
        kbBtn.Text=keyCode.Name:sub(1,6); kbBtn.TextColor3=Color3.fromRGB(153,68,221)
    end
    return row,kbBtn,tf,setToggleKB,setKeyBtn
end

