-- Ghost Mode
local ghostActive=false
local invisOrigTransp={}
local ghostKey=Enum.KeyCode.H
local ghostKeyEnabled=false

local function ghostApplyTransp(char,makeInvis)
    if not char then return end
    if makeInvis then
        invisOrigTransp={}
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                invisOrigTransp[v]=v.Transparency
                if v.Transparency<0.5 then v.Transparency=0.5 end
            end
        end
    else
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                local orig=invisOrigTransp[v]; v.Transparency=orig~=nil and orig or 0
            end
        end
        invisOrigTransp={}
    end
end

