-- Toggle row
local function makeToggleRow(parent,order,label,defaultOn,onChange)
    local row=makeRow(parent,order,44); makeLbl(row,label,11)
    local tf=makeToggle(row,nil,defaultOn)
    if onChange then tf.AttributeChanged:Connect(function(a) if a=="IsOn" then onChange(tf:GetAttribute("IsOn")) end end) end
    local tiTF=TweenInfo.new(0.12,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
    local function setToggle(v)
        tf:SetAttribute("IsOn",v)
        TS:Create(tf,tiTF,{BackgroundColor3=v and Color3.fromRGB(61,0,107) or Color3.fromRGB(17,17,17)}):Play()
        local s=tf:FindFirstChildOfClass("UIStroke"); if s then s.Color=v and Color3.fromRGB(119,0,187) or Color3.fromRGB(34,0,56) end
        local knob=tf:FindFirstChild("Knob")
        if knob then TS:Create(knob,tiTF,{Position=v and UDim2.fromOffset(19,3) or UDim2.fromOffset(3,3),BackgroundColor3=v and Color3.fromRGB(187,119,255) or Color3.fromRGB(85,85,85)}):Play() end
    end
    return row,tf,setToggle
end

