-- ==================== HELPERS ====================

local connections = {}

local function createconnection(name, source, callback)
    if connections[name] then connections[name]:Disconnect() end
    local signal =
        typeof(source) == "string" and RunService[source]
        or typeof(source) == "RBXScriptSignal" and source
        or nil
    if not signal then return nil end
    connections[name] = signal:Connect(callback)
    return connections[name]
end

local function closeconnection(name)
    if connections[name] then
        connections[name]:Disconnect()
        connections[name] = nil
        return true
    end
    return false
end

