local function hasLOS(from,to)
    if not autoShotConfig.wallCheck then return true end
    local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Blacklist
    rp.FilterDescendantsInstances={LP.Character}
    local r=workspace:Raycast(from,to-from,rp)
    if r then local m=r.Instance:FindFirstAncestorOfClass("Model")
        return m and Players:GetPlayerFromCharacter(m) and true or false end
    return true
end
local function AcharMelhorAlvo()
    local char=LP.Character; if not char then return nil end
    local myHRP=char:FindFirstChild("HumanoidRootPart"); if not myHRP then return nil end
    local myPos=myHRP.Position; local best=nil; local bScore=-math.huge
    for _,v in pairs(Players:GetPlayers()) do
        if v~=LP and v.Parent and v.Character and v.Character.Parent then
            local hrp=v.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local bp=v:FindFirstChild("Backpack")
                if v.Character:FindFirstChild("Knife") or (bp and bp:FindFirstChild("Knife")) then
                    local d=(hrp.Position-myPos).Magnitude
                    local sc=1500-d+(autoShotConfig.wallCheck and hasLOS(myPos,hrp.Position) and 500 or 0)-hrp.Velocity.Magnitude*5
                    local hum=hrp.Parent:FindFirstChild("Humanoid")
                    if hum then local st=hum:GetState()
                        if st~=Enum.HumanoidStateType.Freefall and st~=Enum.HumanoidStateType.Flying then sc=sc+200 end end
                    if sc>bScore then bScore=sc; best=hrp end
                end
            end
        end
    end
    return best
end
local function DesequiparArma()
    local char=LP.Character; if not char then return end
    if char:FindFirstChild("Gun") then local h=char:FindFirstChild("Humanoid")
        if h then pcall(function() h:UnequipTools() end) end end
end
local function Atirar()
    if not podeAtirar then return end
    local char=LP.Character; if not char or not char.Parent then return end
    local hum=char:FindFirstChild("Humanoid"); if not hum or hum.Health<=0 then return end
    local head=char:FindFirstChild("Head"); if not head then return end
    local alvo=AcharMelhorAlvo(); if not alvo or not alvo.Parent then return end
    local humAlvo=alvo.Parent:FindFirstChild("Humanoid"); if not humAlvo or humAlvo.Health<=0 then return end
    local headAlvo=alvo.Parent:FindFirstChild("Head"); if not headAlvo then return end
    if (headAlvo.Position-head.Position).Magnitude>sheriffConfig.MaxPredictionDistance then return end
    if autoShotConfig.wallCheck and not hasLOS(head.Position,alvo.Position) then return end
    local arma=char:FindFirstChild("Gun")
    if not arma then
        if equipAttempts>=3 then equipAttempts=0; return end
        local g=LP.Backpack and LP.Backpack:FindFirstChild("Gun"); if not g then equipAttempts=0; return end
        equipAttempts=equipAttempts+1
        task.spawn(function() pcall(function() hum:EquipTool(g) end); task.wait(0.05); if podeAtirar then Atirar() end end); return
    end
    equipAttempts=0; local ev=arma:FindFirstChild("Shoot"); if not ev then return end
    local function fire()
        if not podeAtirar then return end
        if not alvo or not alvo.Parent then return end
        if not humAlvo or humAlvo.Health<=0 then return end
        local pp=CalcularPredicao(alvo,headAlvo,head.Position); if not pp then return end
        pcall(function() ev:FireServer(CFrame.new(head.Position,pp),CFrame.new(pp)) end)
        podeAtirar=false
        local dist=(headAlvo.Position-head.Position).Magnitude
        local ad=dist<50 and delayTiro*0.7 or dist<120 and delayTiro or dist<220 and delayTiro*1.3 or delayTiro*1.6
        task.delay(ad,function() podeAtirar=true end)
        if sheriffConfig.UnequipAfterShot then task.delay(delayHolster>0 and delayHolster or 0.05,DesequiparArma) end
    end
    local st=humAlvo:GetState(); local vy=alvo.Velocity.Y
    local noApex=(st==Enum.HumanoidStateType.Freefall or st==Enum.HumanoidStateType.Jumping) and math.abs(vy)<8
    if noApex then
        podeAtirar=false; local ac; local th=task.delay(0.12,function()
            if ac then ac:Disconnect(); ac=nil end; podeAtirar=true; fire()
        end)
        ac=RunService.Heartbeat:Connect(function()
            if not ac then return end
            if not alvo or not alvo.Parent then ac:Disconnect();ac=nil;task.cancel(th);podeAtirar=true;return end
            if alvo.Velocity.Y<-5 then ac:Disconnect();ac=nil;task.cancel(th);podeAtirar=true;fire() end
        end)
    else fire() end
end

