local function makeSliderRow(parent,order,label,minV,maxV,defaultV,onChange)
    local row=makeRow(parent,order,44); makeLbl(row,label,11)
    local wrap=Instance.new("Frame",row); wrap.Size=UDim2.new(0,130,0,18)
    wrap.Position=UDim2.new(1,-168,0.5,-9); wrap.Name="SliderWrap"; wrap.BackgroundTransparency=1
    local bg=Instance.new("Frame",wrap); bg.BorderSizePixel=0
    bg.BackgroundColor3=Color3.fromRGB(35,0,57); bg.Size=UDim2.new(1,-32,0,4)
    bg.Position=UDim2.new(0,0,0,7); bg.Name="SliderBG"; corner(bg,2)
    local fill=Instance.new("Frame",bg); fill.BorderSizePixel=0
    fill.BackgroundColor3=Color3.fromRGB(120,0,188); fill.Name="Fill"; corner(fill,2)
    local knob=Instance.new("Frame",bg); knob.BorderSizePixel=0
    knob.BackgroundColor3=Color3.fromRGB(120,0,188); knob.Size=UDim2.new(0,12,0,12)
    knob.Name="Knob"; corner(knob,6)
    local valLbl=Instance.new("TextLabel",wrap); valLbl.TextSize=10
    valLbl.FontFace=Font.new("rbxasset://fonts/families/GothamSSm.json",Enum.FontWeight.Regular)
    valLbl.TextColor3=Color3.fromRGB(154,69,222); valLbl.BackgroundTransparency=1
    -- área maior para facilitar toque no mobile
    valLbl.Size=UDim2.new(0,44,0,36); valLbl.Name="Val"; valLbl.Position=UDim2.new(1,-46,0.5,-18)
    valLbl.TextSize=11
    -- TextBox para digitação manual
    local tbox=Instance.new("TextBox",valLbl); tbox.Name="SliderInput"
    tbox.AnchorPoint=Vector2.new(0.5,0.5)
    tbox.Size=UDim2.new(1,0,0,24); tbox.Position=UDim2.new(0.5,0,0.5,0)
    tbox.BackgroundColor3=Color3.fromRGB(20,0,34)
    tbox.BackgroundTransparency=1; tbox.TextColor3=Color3.fromRGB(204,136,255)
    tbox.Font=Enum.Font.GothamBold; tbox.TextSize=11; tbox.Text=""
    tbox.PlaceholderText="0"; tbox.ClearTextOnFocus=true; tbox.BorderSizePixel=0
    tbox.ZIndex=(valLbl.ZIndex or 1)+2; tbox.Visible=false; corner(tbox,3)
    mkS(tbox,Color3.fromRGB(80,0,140))
    local isInt=(maxV-minV)>=10
    local function applyPct(p)
        p=math.clamp(p,0,1)
        local v=minV+(maxV-minV)*p
        local vr=isInt and math.floor(v+0.5) or (math.floor(v*100+0.5)/100)
        fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-6,0.5,-6)
        valLbl.Text=tostring(vr); if onChange then onChange(vr) end
    end
    applyPct((defaultV-minV)/(maxV-minV))
    local sliding=false
    bg.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            sliding=true; applyPct((i.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X) end
    end)
    bg.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliding=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            applyPct((i.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X) end
    end)
    local function openInput()
        tbox.Text=valLbl.Text; tbox.Visible=true; tbox.BackgroundTransparency=0
        task.defer(function() pcall(function() tbox:CaptureFocus() end) end)
    end
    valLbl.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            openInput() end
    end)
    -- toque direto no tbox (mobile) também abre
    tbox.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch and not tbox.Visible then openInput() end
    end)
    tbox.FocusLost:Connect(function()
        tbox.Visible=false; tbox.BackgroundTransparency=1
        local v=tonumber(tbox.Text)
        if v then v=math.clamp(isInt and math.floor(v+0.5) or (math.floor(v*100+0.5)/100),minV,maxV)
            applyPct((v-minV)/(maxV-minV)) end
        tbox.Text=""
    end)
    valLbl.MouseEnter:Connect(function() TS:Create(valLbl,TweenInfo.new(0.1),{TextColor3=Color3.fromRGB(204,136,255)}):Play() end)
    valLbl.MouseLeave:Connect(function() TS:Create(valLbl,TweenInfo.new(0.1),{TextColor3=Color3.fromRGB(154,69,222)}):Play() end)
    local function setSlider(v)
        v=math.clamp(isInt and math.floor(v+0.5) or (math.floor(v*100+0.5)/100),minV,maxV)
        applyPct((v-minV)/(maxV-minV))
    end
    return row,setSlider
end

