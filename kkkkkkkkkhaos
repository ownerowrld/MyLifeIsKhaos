local function CriarGhostBotao()
    if ghostBotaoTela then return end
    local sg = Instance.new("ScreenGui")
    sg.Name           = "GhostModeBtn"
    sg.ResetOnSpawn   = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.IgnoreGuiInset = true

    local container = Instance.new("Frame")
    container.Name                   = "GhostContainer"
    container.Size                   = UDim2.new(0, 80, 0, 80)
    container.Position               = ghostBotaoPos
    container.BackgroundColor3       = Color3.fromRGB(30, 30, 30)
    container.BackgroundTransparency = 0.3
    container.BorderSizePixel        = 0
    container.Parent                 = sg
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 12)

    local stroke = Instance.new("UIStroke")
    stroke.Color           = Color3.fromRGB(140, 50, 255)
    stroke.Thickness       = 2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent          = container

    local label = Instance.new("TextLabel")
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text                   = "GHOST"
    label.TextSize               = 16
    label.Font                   = Enum.Font.GothamBold
    label.TextXAlignment         = Enum.TextXAlignment.Center
    label.TextYAlignment         = Enum.TextYAlignment.Center
    label.TextColor3             = Color3.fromRGB(140, 50, 255)
    label.ZIndex                 = 2
    label.Parent                 = container

    ghostRefContainer = container
    ghostRefStroke    = stroke
    ghostRefLabel     = label

    -- Pulse animation
    local guiViva = true
    sg.Destroying:Connect(function()
        guiViva           = false
        ghostRefContainer = nil
        ghostRefStroke    = nil
        ghostRefLabel     = nil
    end)
    task.spawn(function()
        while guiViva do
            if not ghostActive then
                local t1 = game:GetService("TweenService"):Create(stroke,
                    TweenInfo.new(1, Enum.EasingStyle.Sine), {Transparency = 0.6})
                t1:Play(); t1.Completed:Wait()
                if not guiViva then break end
                local t2 = game:GetService("TweenService"):Create(stroke,
                    TweenInfo.new(1, Enum.EasingStyle.Sine), {Transparency = 0})
                t2:Play(); t2.Completed:Wait()
            else
                stroke.Transparency = 0
                task.wait(0.5)
            end
        end
    end)

    local btn = Instance.new("TextButton")
    btn.Size                = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text                = ""
    btn.AutoButtonColor     = false
    btn.ZIndex              = 4
    btn.Parent              = container

    btn.InputBegan:Connect(function(input)
        local isTouch = input.UserInputType == Enum.UserInputType.Touch
        local isMouse = input.UserInputType == Enum.UserInputType.MouseButton1
        if not (isTouch or isMouse) then return end

        local startPos   = input.Position
        local startFrame = container.Position
        local moved      = false
        local moveConn, endConn

        moveConn = game:GetService("UserInputService").InputChanged:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.MouseMovement
            and inp.UserInputType ~= Enum.UserInputType.Touch then return end
            local delta = inp.Position - startPos
            if not moved and (math.abs(delta.X) > 6 or math.abs(delta.Y) > 6) then
                moved = true
            end
            if moved and ghostBotaoArrastavel then
                container.Position = UDim2.new(
                    startFrame.X.Scale, startFrame.X.Offset + delta.X,
                    startFrame.Y.Scale, startFrame.Y.Offset + delta.Y)
            end
        end)

        endConn = input.Changed:Connect(function()
            if input.UserInputState ~= Enum.UserInputState.End then return end
            moveConn:Disconnect(); endConn:Disconnect()
            if moved and ghostBotaoArrastavel then
                ghostBotaoPos = container.Position
                salvarGhostPos(ghostBotaoPos)
            elseif not moved then
                toggleGhost()
            end
        end)
    end)

    sg.Parent     = game:GetService("CoreGui")
    ghostBotaoTela = sg
end

