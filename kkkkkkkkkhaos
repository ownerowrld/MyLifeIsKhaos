local espConfig = {
    enabled       = false,
    innocentColor = Color3.fromRGB(0,255,0),
    sheriffColor  = Color3.fromRGB(0,38,255),
    murdererColor = Color3.fromRGB(255,0,0),
    nameEnabled   = true,
    nameSize      = 14,
    gunEnabled    = false,
    coinEnabled   = false,
}

local espConnections  = {}
local activeESP       = {}
local espRunning      = false
local roleCache       = {}
local playerDataRemote = nil

local function getPlayerDataRemote()
    if playerDataRemote then return playerDataRemote end
    local ok,r=pcall(function() return game:GetService("ReplicatedStorage"):FindFirstChild("GetPlayerData",true) end)
    if ok and r then playerDataRemote=r end
    return playerDataRemote
end

local rolePollConn = nil
local function startRolePoll()
    if rolePollConn then return end
    rolePollConn = RunService.Heartbeat:Connect(function()
        if not espRunning then return end
        local remote=getPlayerDataRemote(); if not remote then return end
        local ok,data=pcall(function() return remote:InvokeServer() end)
        if ok and type(data)=="table" then
            local nc={}
            for pName,pData in pairs(data) do
                if type(pData)=="table" then
                    nc[pName]=(pData.Dead or not pData.Role or pData.Role=="") and "Lobby" or pData.Role
                end
            end
            roleCache=nc
        end
    end)
end
local function stopRolePoll()
    if rolePollConn then rolePollConn:Disconnect(); rolePollConn=nil end
    roleCache={}
end

local function getRoleColor(playerName)
    local plr=Players:FindFirstChild(playerName)
    if plr then
        local char=plr.Character; local bp=plr:FindFirstChild("Backpack")
        if (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife")) then return espConfig.murdererColor end
        if (char and char:FindFirstChild("Gun"))   or (bp and bp:FindFirstChild("Gun"))   then return espConfig.sheriffColor  end
    end
    local role=roleCache[playerName]
    if role=="Murderer" then return espConfig.murdererColor end
    if role=="Sheriff"  then return espConfig.sheriffColor  end
    return espConfig.innocentColor
end

-- Update loop (throttled, sem while)
local espElapsed=0
createconnection("ESPUpdate",RunService.Heartbeat,function(dt)
    espElapsed=espElapsed+dt
    if espElapsed<0.2 then return end
    espElapsed=0
    if not espConfig.enabled then return end
    for i=#activeESP,1,-1 do
        local e=activeESP[i]
        if not e.character or not e.character.Parent then
            if e.highlight and e.highlight.Parent then e.highlight:Destroy() end
            if e.tag and e.tag.Parent then e.tag:Destroy() end
            table.remove(activeESP,i)
        else
            local color=getRoleColor(e.player.Name)
            e.highlight.OutlineColor=color; e.label.TextColor3=color
            e.label.Text=e.player.Name; e.label.TextSize=espConfig.nameSize
            e.tag.Enabled=espConfig.nameEnabled
        end
    end
end)

local function CleanupPlayer(plr)
    if not plr then return end
    local char=plr.Character; if not char then return end
    local holder=char:FindFirstChild("ESPHolder"); if holder then holder:Destroy() end
    local head=char:FindFirstChild("Head"); if not head then return end
    local tag=head:FindFirstChild("KhaosTag"); if tag then tag:Destroy() end
end

local function ApplyESP(targetPlayer,character)
    if not character then return end
    local head=character:WaitForChild("Head",5); if not head then return end
    local oldHolder=character:FindFirstChild("ESPHolder"); if oldHolder then oldHolder:Destroy() end
    local holder=Instance.new("Folder"); holder.Name="ESPHolder"; holder.Parent=character
    local highlight=Instance.new("Highlight")
    highlight.Name="ESPHighlight"; highlight.Adornee=character
    highlight.FillTransparency=1; highlight.OutlineTransparency=0
    highlight.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    highlight.OutlineColor=getRoleColor(targetPlayer.Name); highlight.Parent=holder
    local oldTag=head:FindFirstChild("KhaosTag"); if oldTag then oldTag:Destroy() end
    local tag=Instance.new("BillboardGui")
    tag.Name="KhaosTag"; tag.Size=UDim2.new(0,200,0,40)
    tag.AlwaysOnTop=true; tag.StudsOffset=Vector3.new(0,1.5,0); tag.Parent=head
    local label=Instance.new("TextLabel")
    label.Name="Label"; label.BackgroundTransparency=1
    label.Size=UDim2.new(1,0,1,0); label.Text=targetPlayer.Name
    label.Font=Enum.Font.GothamBold; label.TextSize=espConfig.nameSize
    label.TextStrokeTransparency=0; label.TextScaled=false
    label.TextColor3=getRoleColor(targetPlayer.Name); label.Parent=tag
    table.insert(activeESP,{player=targetPlayer,character=character,highlight=highlight,tag=tag,label=label})
end

local function CreateESP(targetPlayer)
    if targetPlayer==LP then return end
    if targetPlayer.Character then task.spawn(ApplyESP,targetPlayer,targetPlayer.Character) end
    local ref={player=targetPlayer}
    ref.conn=targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.15); task.spawn(ApplyESP,targetPlayer,char)
    end)
    table.insert(espConnections,ref)
end

local function enablePlayerESP()
    if espRunning then
        espRunning=false; espConfig.enabled=false; stopRolePoll()
    end
    espRunning=true; espConfig.enabled=true
    for _,conn in pairs(espConnections) do if conn.conn and conn.conn.Connected then conn.conn:Disconnect() end end
    for _,e in pairs(activeESP) do
        if e.highlight and e.highlight.Parent then e.highlight:Destroy() end
        if e.tag and e.tag.Parent then e.tag:Destroy() end
    end
    espConnections={}; activeESP={}
    startRolePoll()
    for _,plr in pairs(Players:GetPlayers()) do CreateESP(plr) end
    local addedRef={}; addedRef.conn=Players.PlayerAdded:Connect(CreateESP)
    table.insert(espConnections,addedRef)
    local removingRef={}
    removingRef.conn=Players.PlayerRemoving:Connect(function(plr)
        for i=#activeESP,1,-1 do
            if activeESP[i].player==plr then
                if activeESP[i].highlight and activeESP[i].highlight.Parent then activeESP[i].highlight:Destroy() end
                if activeESP[i].tag and activeESP[i].tag.Parent then activeESP[i].tag:Destroy() end
                table.remove(activeESP,i)
            end
        end
        for i=#espConnections,1,-1 do
            local c=espConnections[i]
            if c.player==plr then
                if c.conn and c.conn.Connected then c.conn:Disconnect() end
                table.remove(espConnections,i)
            end
        end
        CleanupPlayer(plr)
    end)
    table.insert(espConnections,removingRef)
end

local function disablePlayerESP()
    espRunning=false; espConfig.enabled=false; stopRolePoll()
    for _,conn in pairs(espConnections) do if conn.conn and conn.conn.Connected then conn.conn:Disconnect() end end
    for _,e in pairs(activeESP) do
        if e.highlight and e.highlight.Parent then e.highlight:Destroy() end
        if e.tag and e.tag.Parent then e.tag:Destroy() end
    end
    espConnections={}; activeESP={}
    for _,plr in pairs(Players:GetPlayers()) do CleanupPlayer(plr) end
end

