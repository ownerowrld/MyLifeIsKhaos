-- Ghost keybind global
createconnection("GhostKey",UIS.InputBegan,function(i,gp)
    if gp then return end
    if ghostKeyEnabled and i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==ghostKey then
        toggleGhost()
    end
end)

-- Reset ao respawn
createconnection("PlayerRespawnPlayer",LP.CharacterAdded,function(char)
    task.wait(0.3)
    if ghostActive then ghostActive=false; updateGhostBtn() end
    if noclipActive then
        task.wait(0.2); cacheNoclipParts()
    end
end)

