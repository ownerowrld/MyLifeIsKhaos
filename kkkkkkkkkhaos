        local par=btn.Parent; local pA=par and par.AbsolutePosition or Vector2.zero
        _activeDrag={obj=btn,sX=i.Position.X,sY=i.Position.Y,
            oX=btn.AbsolutePosition.X-pA.X,oY=btn.AbsolutePosition.Y-pA.Y,
            moved=false,isWin=false}
